PORT=9000
MONGO_CONNECTION_STRING=mongodb://localhost:27017/bookmytheatre
# Optional: overrides MONGO_CONNECTION_STRING when set (needed for local replica-set transactions)
# MONGO_REPLICA_STRING=mongodb://localhost:27017/bookmytheatre?replicaSet=rs0&directConnection=true
NODEMAILER_EMAIL=
NODEMAILER_PASSWORD=
HASH_SECRET=
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
FRONTEND_URL=http://localhost:5173
# Production (Render): set to your Vercel URL, e.g.
# FRONTEND_URL=https://book-my-theatre-tau.vercel.app
# Multiple origins (comma-separated):
# ALLOWED_ORIGINS=https://book-my-theatre-tau.vercel.app,http://localhost:5173
RAZORPAY_API_KEY=
RAZORPAY_SECRET_KEY=


# Production (Render + Upstash): set one of these — URL takes precedence over host/port
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
# UPSTASH_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
# UPSTASH_REDIS_ENDPOINT=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# Local Docker / dev fallback
REDIS_HOST=127.0.0.1
REDIS_PORT=6379